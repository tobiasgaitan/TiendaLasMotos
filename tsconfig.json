{
  "compilerOptions": {
    // [WEB-752] ES2022: elimina polyfills legacy generados por ES2017 (async/await, class fields, optional chaining).
    // Node 22 (engines) + Firebase Hosting (browsers modernos) soportan ES2022 natiamente.
    // Lib "esnext" existente ya cubre ES2022 — sin riesgo de regresión de tipo.
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "functions"
  ]
}
